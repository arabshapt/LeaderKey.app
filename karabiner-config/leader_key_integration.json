{
  "title": "Leader Key Integration",
  "rules": [
    {
      "description": "Leader Key - Activate with Cmd+K",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "k",
            "modifiers": {
              "mandatory": ["command"]
            }
          },
          "to": [
            {
              "shell_command": "echo 'activate' | nc -U /tmp/leaderkey.sock"
            },
            {
              "set_variable": {
                "name": "leader_mode",
                "value": 1
              }
            }
          ]
        }
      ]
    },
    {
      "description": "Leader Key - Deactivate with Escape",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "escape"
          },
          "to": [
            {
              "key_code": "escape"
            },
            {
              "set_variable": {
                "name": "leader_mode",
                "value": 0
              }
            },
            {
              "shell_command": "echo 'deactivate' | nc -U /tmp/leaderkey.sock"
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "leader_mode",
              "value": 1
            }
          ]
        }
      ]
    },
    {
      "description": "Leader Key - Forward letter keys",
