        {
          "key": "l",
          "type": "url",
          "label": "Raycast: Right Half",
          "description": "Move active window to the right half",
          "voiceId": "window_right_half",
          "voiceAliases": ["right half", "move right", "tile right", "snap right"],
          "value": "raycast://extensions/raycast/window-management/right-half"
